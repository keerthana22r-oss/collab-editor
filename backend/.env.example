# Copy this file to .env and adjust as needed. .env is gitignored.

SECRET_KEY=dev-only-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset to use local SQLite (zero setup). Set this once you have
# Postgres running locally, e.g.:
# DATABASE_URL=postgres://collab_user:collab_pass@localhost:5432/collab_editor
# DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Where Channels' channel layer looks for Redis. Default matches Docker's
# `docker run -p 6379:6379 redis` or a native install like Memurai.
REDIS_URL=redis://127.0.0.1:6379
